vcl 4.0;

# Backend definition - Nginx on port {{ nginx_port | default(8080) }}
backend default {
    .host = "127.0.0.1";
    .port = "{{ nginx_port | default('8080') }}";
}

# Student ID for tracking
sub vcl_recv {
    set req.http.X-Student-ID = "{{ student_id }}";
    
    # Only cache GET and HEAD
    if (req.method != "GET" && req.method != "HEAD") {
        return (pass);
    }
    
    # Remove cookies for static content
    unset req.http.cookie;
}

sub vcl_backend_response {
    # Set longer TTL for static assets
    if (bereq.url ~ "\.(css|js|png|gif|jpg|jpeg|ico|svg|woff2|ttf)$") {
        set beresp.ttl = 24h;
    }
    
    # Don't cache errors
    if (beresp.status >= 400) {
        set beresp.ttl = 0s;
    }
}

sub vcl_deliver {
    # Add cache hit/miss headers
    if (obj.hits > 0) {
        set resp.http.X-Cache = "HIT";
    } else {
        set resp.http.X-Cache = "MISS";
    }
    
    # Add student ID to response
    set resp.http.X-Student = "{{ student_id }}";
}
